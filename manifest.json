{
  "manifest_version": 3,
  "name": "CUHKSZ ITSO Helper",
  "version": "0.1.0",
  "description": "Run the CUHK-Shenzhen network report and speed test, then show the result in the popup.",
  "minimum_chrome_version": "109",
  "permissions": [
    "storage",
    "webRequest",
    "clipboardWrite",
    "offscreen",
    "notifications"
  ],
  "host_permissions": [
    "https://nt-r.cuhk.edu.cn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://nt-r.cuhk.edu.cn/*"
      ],
      "js": [
        "site-runner.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png"
    },
    "default_title": "CUHKSZ ITSO Helper",
    "default_popup": "popup.html"
  }
}
